generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  QUOTATION_SENT
  QUOTATION_FINALIZED
  APPROVED
  REJECTED
}

enum QuotationStatus {
  DRAFT
  SENT
  FINALIZED
}

enum CommentSender {
  ADMIN
  CUSTOMER
}

model Booking {
  id                String        @id @default(cuid())
  bookingId         String        @unique
  name              String
  phone             String
  date              DateTime      @db.Date
  eventType         String
  numberOfAttendees Int           @default(0)
  notes             String?
  status            BookingStatus @default(PENDING)
  secretCode        String?       @unique
  adminNote         String?
  totalAmount       Float?
  advanceAmount     Float?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  comments          Comment[]
  quotation         Quotation?

  @@index([date])
  @@index([status])
}

model Quotation {
  id            String          @id @default(cuid())
  booking       Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId     String          @unique
  status        QuotationStatus @default(DRAFT)
  totalAmount   Float
  advanceAmount Float           @default(0)
  notes         String?
  items         QuotationItem[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  finalizedAt   DateTime?
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  quotationId String
  particular  String
  quantity    Int?
  unit        String?
  rate        Float?
  amount      Float
  order       Int       @default(0)

  @@index([quotationId])
}

model Comment {
  id        String        @id @default(cuid())
  message   String
  sender    CommentSender
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String
  createdAt DateTime      @default(now())

  @@index([bookingId])
}

model BlockedDate {
  id     String   @id @default(cuid())
  date   DateTime @unique @db.Date
  reason String?
}

model MediaFile {
  id           String   @id @default(cuid())
  url          String
  publicId     String   @unique
  fileName     String
  fileSize     Int // bytes
  mimeType     String
  resourceType String // "image" or "video"
  width        Int?
  height       Int?
  createdAt    DateTime @default(now())

  carouselImages HeroCarouselImage[]
  galleryItems   GalleryItem[]
  heroSections   HeroSection[]       @relation("HeroLogo")
}

model HeroSection {
  id               String     @id @default(cuid())
  subtitle         String
  heading          String
  headingHighlight String
  description      String
  logoUrl          String?
  logoMediaFileId  String?
  logoMedia        MediaFile? @relation("HeroLogo", fields: [logoMediaFileId], references: [id])
  updatedAt        DateTime   @updatedAt
}

model GalleryItem {
  id          String     @id @default(cuid())
  title       String
  desc        String
  imageUrl    String
  gradient    String     @default("from-amber-600 to-amber-800")
  order       Int        @default(0)
  visible     Boolean    @default(true)
  mediaFileId String?
  mediaFile   MediaFile? @relation(fields: [mediaFileId], references: [id])

  @@index([order])
}

model ServiceItem {
  id      String  @id @default(cuid())
  title   String
  desc    String
  iconSvg String
  order   Int     @default(0)
  visible Boolean @default(true)

  @@index([order])
}

model HeroCarouselImage {
  id          String     @id @default(cuid())
  imageUrl    String
  alt         String     @default("")
  order       Int        @default(0)
  visible     Boolean    @default(true)
  mediaFileId String?
  mediaFile   MediaFile? @relation(fields: [mediaFileId], references: [id])

  @@index([order])
}

model StatItem {
  id      String  @id @default(cuid())
  value   Int
  suffix  String  @default("")
  label   String
  order   Int     @default(0)
  visible Boolean @default(true)

  @@index([order])
}

model SiteSettings {
  id               String   @id @default("default")
  themeMode        String   @default("PRESET")
  themePreset      String   @default("amber")
  themePrimaryHex  String?
  themeAccentHex   String?
  instagramEnabled Boolean  @default(true)
  instagramUrl     String?
  mapsEnabled      Boolean  @default(true)
  mapsEmbedUrl     String?
  mapsLinkUrl      String?
  whatsappEnabled  Boolean  @default(false)
  whatsappPhone    String?
  addressLine1     String?
  addressLine2     String?
  contactPhone     String?
  contactEmail     String?
  aboutBlurb       String?
  metaDescription  String?
  updatedAt        DateTime @updatedAt
}
